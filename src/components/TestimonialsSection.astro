---
import TestimonialCard from './TestimonialCard.astro';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/translations';
import { parse } from 'yaml';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

interface Testimonial {
  author: string;
  company: string;
  role_ro: string;
  role_en: string;
  quote_ro: string;
  quote_en: string;
  rating: number;
  featured: boolean;
  verified: boolean;
}

// Read testimonials from YAML using Vite's glob import for raw text
let testimonials: Testimonial[] = [];
try {
  const yamlFiles = import.meta.glob('../content/testimonials.yaml', { query: '?raw', import: 'default', eager: true });
  const yamlContent = Object.values(yamlFiles)[0] as string;
  testimonials = parse(yamlContent) as Testimonial[];
} catch (e) {
  console.error("Failed to parse YAML", e);
}

const featured = testimonials.filter(t => t.featured);
const others = testimonials.filter(t => !t.featured);
const featuredDelays = ['', 'delay-100', 'delay-200', 'delay-300'];
const otherDelays = ['', 'delay-100', 'delay-200', 'delay-300'];
---

<section class="py-20 lg:py-28 relative overflow-hidden bg-surface-dark">
  <!-- Large decorative quote watermarks -->
  <div class="absolute top-8 left-8 text-[16rem] leading-none font-serif text-white/[0.02] pointer-events-none select-none">&ldquo;</div>
  <div class="absolute bottom-8 right-8 text-[16rem] leading-none font-serif text-white/[0.02] pointer-events-none select-none rotate-180">&ldquo;</div>

  <!-- Subtle gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-blue/5 via-transparent to-brand-teal/5 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16" data-animate>
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-teal/10 text-brand-teal text-sm font-medium mb-6 border border-brand-teal/20">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 13V5a2 2 0 00-2-2H4a2 2 0 00-2 2v8a2 2 0 002 2h3l3 3 3-3h3a2 2 0 002-2z" clip-rule="evenodd" />
        </svg>
        {t(lang, 'testimonials.featured')}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
        {t(lang, 'testimonials.title')}
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        {t(lang, 'testimonials.subtitle')}
      </p>
      <div class="mt-6 w-20 h-1 bg-gradient-to-r from-brand-teal to-brand-blue mx-auto rounded-full"></div>
    </div>

    <!-- Featured Testimonials - Masonry-style grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-8">
      {featured.map((testimonial, i) => (
        <TestimonialCard
          quote={lang === 'ro' ? testimonial.quote_ro : testimonial.quote_en}
          author={testimonial.author}
          company={testimonial.company}
          role={lang === 'ro' ? testimonial.role_ro : testimonial.role_en}
          rating={testimonial.rating}
          featured={true}
          verified={testimonial.verified}
          delay={featuredDelays[i] || ''}
          readMoreLabel={t(lang, 'testimonials.readMore')}
          readLessLabel={t(lang, 'testimonials.readLess')}
          verifiedLabel={t(lang, 'testimonials.verified')}
        />
      ))}
    </div>

    <!-- Divider with label -->
    <div class="flex items-center gap-4 my-10" data-animate>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent to-white/10"></div>
      <span class="text-xs uppercase tracking-widest text-slate-500 font-medium">{t(lang, 'testimonials.allReviews')}</span>
      <div class="flex-1 h-px bg-gradient-to-l from-transparent to-white/10"></div>
    </div>

    <!-- Other Testimonials - Scrolling row -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {others.map((testimonial, i) => (
        <TestimonialCard
          quote={lang === 'ro' ? testimonial.quote_ro : testimonial.quote_en}
          author={testimonial.author}
          company={testimonial.company}
          role={lang === 'ro' ? testimonial.role_ro : testimonial.role_en}
          rating={testimonial.rating}
          featured={false}
          verified={testimonial.verified}
          delay={otherDelays[i] || ''}
          readMoreLabel={t(lang, 'testimonials.readMore')}
          readLessLabel={t(lang, 'testimonials.readLess')}
          verifiedLabel={t(lang, 'testimonials.verified')}
        />
      ))}
    </div>
  </div>
</section>
