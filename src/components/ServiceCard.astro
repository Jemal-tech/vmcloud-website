---
interface Props {
  title: string;
  description: string;
  icon: string;
  delay?: string;
}

const { title, description, icon, delay = '' } = Astro.props;

// Unique glow ID per icon to avoid SVG namespace collisions
const glowId = `svc-glow-${icon}`;

// Brand color constants for dual-tone icon system
const PRIMARY = '#00d1d1';
const SECONDARY = 'rgba(148,163,184,0.4)';

// Premium dual-tone SVG icons — primary (#00d1d1 bright Teal/Cyan) + secondary (dimmed Slate-400)
const iconData: Record<string, { primary: string; secondary: string }> = {
  // Administrare IT: Server Rack with Shield overlay and LED status dots
  monitor: {
    secondary: `
      <rect x="3" y="2" width="12" height="20" rx="2"/>
      <line x1="3" y1="9" x2="15" y2="9"/>
      <line x1="3" y1="15.5" x2="15" y2="15.5"/>
    `,
    primary: `
      <circle cx="6.5" cy="5.5" r="1" fill="${PRIMARY}" stroke="none"/>
      <circle cx="9" cy="5.5" r="1" fill="${PRIMARY}" stroke="none"/>
      <circle cx="6.5" cy="12.2" r="1" fill="${PRIMARY}" stroke="none"/>
      <circle cx="9" cy="12.2" r="1" fill="${PRIMARY}" stroke="none"/>
      <circle cx="6.5" cy="18.8" r="1" fill="${PRIMARY}" stroke="none"/>
      <line x1="11.5" y1="5.5" x2="13.5" y2="5.5"/>
      <line x1="11.5" y1="12.2" x2="13.5" y2="12.2"/>
      <path d="M20 11.5L17.5 13v3c0 1.5 1 2.8 2.5 3.5 1.5-.7 2.5-2 2.5-3.5v-3L20 11.5z"/>
    `,
  },

  // Monitorizare 24/7: Terminal window with steady Pulse line and Clock indicator
  activity: {
    secondary: `
      <rect x="1.5" y="3" width="19" height="13" rx="2"/>
      <line x1="1.5" y1="7" x2="20.5" y2="7"/>
      <circle cx="4" cy="5" r="0.75" fill="${SECONDARY}" stroke="none"/>
      <circle cx="6.5" cy="5" r="0.75" fill="${SECONDARY}" stroke="none"/>
      <circle cx="9" cy="5" r="0.75" fill="${SECONDARY}" stroke="none"/>
    `,
    primary: `
      <polyline points="4 12 6.5 12 8 9 10.5 15 12.5 10.5 14.5 13 16 11.5 18.5 11.5"/>
      <circle cx="20" cy="20" r="2.5"/>
      <polyline points="20 18 20 20 21.5 20.8" stroke-width="1.5"/>
    `,
  },

  // Webhosting & Email: Cloud with Global Grid pattern and sleek Envelope
  globe: {
    secondary: `
      <path d="M20 10.5H8a4 4 0 0 1 0-8A6 6 0 0 1 20 4a3.25 3.25 0 0 1 0 6.5z"/>
      <ellipse cx="12" cy="6.5" rx="2.5" ry="3.5" stroke-width="1" fill="none"/>
      <line x1="7" y1="5.5" x2="17.5" y2="5.5" stroke-width="1"/>
      <line x1="6" y1="8.5" x2="18.5" y2="8.5" stroke-width="1"/>
    `,
    primary: `
      <rect x="6" y="14" width="10" height="6" rx="1.5"/>
      <path d="M6 15.5l5 2.5 5-2.5"/>
    `,
  },

  // Arhitectură IT: Node-and-Link secure infrastructure mesh (4 nodes)
  network: {
    secondary: `
      <line x1="12" y1="4" x2="5" y2="12"/>
      <line x1="12" y1="4" x2="19" y2="12"/>
      <line x1="5" y1="12" x2="12" y2="20"/>
      <line x1="19" y1="12" x2="12" y2="20"/>
      <line x1="5" y1="12" x2="19" y2="12"/>
    `,
    primary: `
      <rect x="9.5" y="1.5" width="5" height="5" rx="1.5"/>
      <rect x="2.5" y="9.5" width="5" height="5" rx="1.5"/>
      <rect x="16.5" y="9.5" width="5" height="5" rx="1.5"/>
      <rect x="9.5" y="17.5" width="5" height="5" rx="1.5"/>
    `,
  },

  // Protecție Malware: Hexagonal Shield with Digital Lock core and Radar sweeps
  shield: {
    secondary: `
      <path d="M12 2L21 7v8l-9 7-9-7V7l9-5z"/>
      <path d="M12 7a5 5 0 0 1 4.3 2.5" stroke-width="1.5" fill="none"/>
      <path d="M12 5a7 7 0 0 1 6 3.5" stroke-width="1" fill="none"/>
    `,
    primary: `
      <rect x="9.5" y="12.5" width="5" height="4" rx="1"/>
      <path d="M10.5 12.5v-1.5a1.5 1.5 0 0 1 3 0v1.5"/>
      <circle cx="12" cy="14.5" r="0.7" fill="${PRIMARY}" stroke="none"/>
    `,
  },

  // Backup & Recovery: Database cylinder with Recursive Loop arrow
  database: {
    secondary: `
      <ellipse cx="12" cy="5" rx="7" ry="2.5"/>
      <path d="M5 5v4c0 1.4 3.1 2.5 7 2.5s7-1.1 7-2.5V5"/>
      <path d="M5 9v4c0 1.4 3.1 2.5 7 2.5s7-1.1 7-2.5V9"/>
    `,
    primary: `
      <path d="M16.5 18a4.5 4.5 0 1 1-2-3.5"/>
      <polyline points="15.5 13 14.5 16 17.5 16"/>
    `,
  },
};

const data = iconData[icon] || iconData.monitor;
---

<div
  class:list={[
    'group relative flex flex-col h-full w-full rounded-2xl overflow-hidden',
    'bg-[#080f1f]',
    'border border-slate-700/40',
    'transition-all duration-500 ease-out',
    'hover:-translate-y-1',
    'hover:border-brand-teal/60',
    'hover:shadow-[0_0_0_1px_rgba(0,184,148,0.6),0_16px_48px_rgba(0,184,148,0.18)]',
    'p-8',
    delay,
  ]}
  data-animate
>
  <!-- Top glow radial — teal inner glow visible on hover -->
  <div
    class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"
    style="background: radial-gradient(ellipse 70% 45% at 50% -5%, rgba(0,184,148,0.12) 0%, transparent 65%);"
  ></div>

  <!-- Icon container — glassmorphic with gradient background -->
  <div
    class:list={[
      'relative flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center mb-6',
      'bg-gradient-to-br from-brand-blue/20 to-brand-teal/10',
      'border border-slate-600/30',
      'shadow-[0_0_16px_rgba(0,209,209,0.08),inset_0_1px_0_rgba(255,255,255,0.07)]',
      'transition-all duration-500',
      'group-hover:border-brand-teal/40',
      'group-hover:scale-110',
      'group-hover:shadow-[0_0_24px_rgba(0,184,148,0.4),inset_0_1px_0_rgba(255,255,255,0.12)]',
    ]}
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id={glowId} cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color={PRIMARY} stop-opacity="0.18"/>
          <stop offset="100%" stop-color={PRIMARY} stop-opacity="0"/>
        </radialGradient>
      </defs>
      <!-- Brand Glow -->
      <circle cx="12" cy="12" r="11" fill={`url(#${glowId})`}/>
      <!-- Secondary (dimmed Slate-400) elements -->
      <g stroke={SECONDARY} fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={data.secondary}/>
      <!-- Primary (bright Teal/Cyan) elements -->
      <g stroke={PRIMARY} fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={data.primary}/>
    </svg>
  </div>

  <!-- Text content -->
  <div class="flex-1 min-w-0">
    <h3 class="font-bold text-xl text-white leading-snug mb-3 group-hover:text-brand-teal transition-colors duration-300">
      {title}
    </h3>
    <p class="text-sm text-slate-400 leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Bottom gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-teal/0 to-transparent group-hover:via-brand-teal/60 transition-all duration-500"></div>
</div>
