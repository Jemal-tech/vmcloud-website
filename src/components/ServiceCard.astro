---
interface Props {
  title: string;
  description: string;
  icon: string;
  delay?: string;
  featured?: boolean;
}

const { title, description, icon, delay = '', featured = false } = Astro.props;

// Unique gradient ID per icon to avoid SVG namespace collisions
const gradId = `svc-grad-${icon}`;

// High-tech line-art SVG paths — gradient stroke applied via parent <g>
const iconPaths: Record<string, string> = {
  monitor: `
    <rect x="2" y="3" width="20" height="13" rx="2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M8 21h8M12 17v4" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M7 8h4M7 11.5h6" stroke-width="1.5" stroke-linecap="round"/>
  `,
  activity: `
    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="12" cy="12" r="1" stroke-width="1.5"/>
  `,
  globe: `
    <circle cx="12" cy="12" r="9" stroke-width="1.5"/>
    <path d="M3.6 9h16.8M3.6 15h16.8" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M12 3C9.8 6.5 9.8 17.5 12 21M12 3C14.2 6.5 14.2 17.5 12 21" stroke-width="1.5" stroke-linecap="round"/>
  `,
  network: `
    <circle cx="12" cy="4.5" r="2" stroke-width="1.5"/>
    <circle cx="4.5" cy="19.5" r="2" stroke-width="1.5"/>
    <circle cx="19.5" cy="19.5" r="2" stroke-width="1.5"/>
    <path d="M12 6.5v3.5M10.5 18L5.5 17.5M13.5 18L18.5 17.5M10.5 10l-4.5 7.5M13.5 10l4.5 7.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  `,
  shield: `
    <path d="M12 2.5L4 6.5v5.5c0 5 3.6 9.7 8 11.2 4.4-1.5 8-6.2 8-11.2V6.5z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M9 12l2 2 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  `,
  database: `
    <ellipse cx="12" cy="6" rx="8" ry="3" stroke-width="1.5"/>
    <path d="M4 6v4c0 1.657 3.582 3 8 3s8-1.343 8-3V6" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M4 14v4c0 1.657 3.582 3 8 3s8-1.343 8-3v-4" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M4 10v4M20 10v4" stroke-width="1.5" stroke-linecap="round"/>
  `,
};

const iconPath = iconPaths[icon] || iconPaths.monitor;
---

<div
  class:list={[
    'group relative flex flex-col h-full rounded-2xl overflow-hidden',
    'bg-slate-950/60 backdrop-blur-xl',
    'border border-white/[0.07]',
    'transition-all duration-500 ease-out',
    'hover:-translate-y-1.5',
    'hover:border-brand-teal/40',
    'hover:shadow-[0_8px_40px_-8px_rgba(0,184,148,0.2),0_0_0_1px_rgba(0,184,148,0.15)]',
    featured ? 'p-7 lg:p-9' : 'p-6 lg:p-8',
    delay,
  ]}
  data-animate
>
  <!-- Top glow radial — visible on hover -->
  <div
    class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"
    style="background: radial-gradient(ellipse 80% 50% at 50% -10%, color-mix(in srgb, var(--color-brand-teal) 10%, transparent) 0%, transparent 70%);"
  ></div>

  <!-- Icon container -->
  <div
    class:list={[
      'relative flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center',
      'bg-gradient-to-br from-brand-blue/15 to-brand-teal/15',
      'border border-white/[0.07] group-hover:border-brand-teal/30',
      'transition-all duration-500',
      'group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(0,184,148,0.35)]',
      featured ? 'mb-6' : 'mb-5',
    ]}
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--color-brand-blue)" />
          <stop offset="100%" stop-color="var(--color-brand-teal)" />
        </linearGradient>
      </defs>
      <g stroke={`url(#${gradId})`} fill="none" set:html={iconPath} />
    </svg>
  </div>

  <!-- Text content -->
  <div class="flex-1 min-w-0">
    <h3
      class:list={[
        'font-bold text-white leading-snug mb-2.5',
        featured ? 'text-xl lg:text-2xl' : 'text-lg',
        'group-hover:text-brand-teal transition-colors duration-300',
      ]}
    >
      {title}
    </h3>
    <p class="text-sm text-slate-400 leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Bottom gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-teal/0 to-transparent group-hover:via-brand-teal/60 transition-all duration-500"></div>
</div>
