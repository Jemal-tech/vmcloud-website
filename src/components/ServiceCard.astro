---
interface Props {
  title: string;
  description: string;
  icon: string;
  delay?: string;
}

const { title, description, icon, delay = '' } = Astro.props;

// Unique gradient ID per icon to avoid SVG namespace collisions
const gradId = `svc-grad-${icon}`;

// Premium dual-tone gradient SVG icons — advanced designs per service type
const iconPaths: Record<string, string> = {
  // IT Administration: System terminal screen with shield overlay badge at bottom-right corner
  monitor: `
    <rect x="1" y="2" width="18" height="12" rx="2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M6.5 21h7M10 14v7" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M4.5 7.5l2.5 1.5-2.5 1.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M9.5 10.5h5.5" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M18.5 12l-2 1-2-1v1.8c0 .85 1 1.6 2 1.9 1-.3 2-1.05 2-1.9z" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
  `,
  // 24/7 Monitoring: Heartbeat ECG pulse line passing through a radar circle
  activity: `
    <circle cx="12" cy="12" r="9" stroke-width="1.5"/>
    <circle cx="12" cy="12" r="5" stroke-width="0.8" stroke-dasharray="2 1.5"/>
    <polyline points="3 12 6 12 8 7.5 10.5 16.5 13 9 15 14 17 12 21 12" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  `,
  // Webhosting & Email: Cloud shape with envelope (fiber-optic cloud connection)
  globe: `
    <path d="M20.5 11H8.5a4.5 4.5 0 0 1 0-9A6.5 6.5 0 0 1 20.5 4a3.5 3.5 0 0 1 0 7z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="7" y="13" width="10" height="6" rx="1" stroke-width="1.5"/>
    <path d="M7 14.5l5.5 3L18 14.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  `,
  // IT Architecture: 3D isometric cube / node-tree blueprint
  network: `
    <path d="M12 2l8 4.5v9L12 20 4 15.5v-9z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M12 2v18" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M4 6.5L12 11l8-4.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  `,
  // Malware Protection: Shield with biometric fingerprint scan arcs
  shield: `
    <path d="M12 2.5L3.5 6v5.5c0 5.2 3.7 10 8.5 11.5 4.8-1.5 8.5-6.3 8.5-11.5V6z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M9.5 12c0-1.38 1.12-2.5 2.5-2.5" stroke-width="1.3" stroke-linecap="round"/>
    <path d="M8.5 14.5c0-1.93 1.57-3.5 3.5-3.5" stroke-width="1.3" stroke-linecap="round"/>
    <path d="M7.5 17c0-2.49 2.01-4.5 4.5-4.5" stroke-width="1.3" stroke-linecap="round"/>
    <circle cx="12" cy="12" r="1" stroke-width="1.3" fill="none"/>
  `,
  // Backup & Recovery: Double database cylinder with circular sync arrow
  database: `
    <ellipse cx="12" cy="4" rx="6.5" ry="2" stroke-width="1.5"/>
    <path d="M5.5 4v4c0 1.1 2.91 2 6.5 2s6.5-.9 6.5-2V4" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M5.5 8v3c0 1.1 2.91 2 6.5 2s6.5-.9 6.5-2V8" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M8.5 19.5a3.5 3.5 0 0 0 7 0M15.5 17.5l1.5 2.5M15.5 17.5l-1.5 2.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  `,
};

const iconPath = iconPaths[icon] || iconPaths.monitor;
---

<div
  class:list={[
    'group relative flex flex-col h-full w-full rounded-2xl overflow-hidden',
    'bg-[#080f1f]',
    'border border-slate-700/40',
    'transition-all duration-500 ease-out',
    'hover:-translate-y-1',
    'hover:border-brand-teal/60',
    'hover:shadow-[0_0_0_1px_rgba(0,184,148,0.6),0_16px_48px_rgba(0,184,148,0.18)]',
    'p-8',
    delay,
  ]}
  data-animate
>
  <!-- Top glow radial — teal inner glow visible on hover -->
  <div
    class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"
    style="background: radial-gradient(ellipse 70% 45% at 50% -5%, rgba(0,184,148,0.12) 0%, transparent 65%);"
  ></div>

  <!-- Icon container — glassmorphic with gradient background -->
  <div
    class:list={[
      'relative flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center mb-6',
      'bg-gradient-to-br from-brand-blue/20 to-brand-teal/10',
      'border border-slate-600/30',
      'shadow-[inset_0_1px_0_rgba(255,255,255,0.07)]',
      'transition-all duration-500',
      'group-hover:border-brand-teal/40',
      'group-hover:scale-110',
      'group-hover:shadow-[0_0_24px_rgba(0,184,148,0.4),inset_0_1px_0_rgba(255,255,255,0.12)]',
    ]}
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--color-brand-blue)" />
          <stop offset="100%" stop-color="var(--color-brand-teal)" />
        </linearGradient>
      </defs>
      <g stroke={`url(#${gradId})`} fill="none" set:html={iconPath} />
    </svg>
  </div>

  <!-- Text content -->
  <div class="flex-1 min-w-0">
    <h3 class="font-bold text-xl text-white leading-snug mb-3 group-hover:text-brand-teal transition-colors duration-300">
      {title}
    </h3>
    <p class="text-sm text-slate-400 leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Bottom gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-teal/0 to-transparent group-hover:via-brand-teal/60 transition-all duration-500"></div>
</div>
