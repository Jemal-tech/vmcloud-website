---
import { getNavItems, t, getLocalizedPath } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const navItems = getNavItems(lang);
const currentYear = new Date().getFullYear();
---

<footer class="relative mt-auto border-t border-slate-900/10 dark:border-white/5">
  <!-- Gradient accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-teal to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href={getLocalizedPath(lang, '/')} class="inline-block mb-4">
          <img src="/logo.png" alt="VMCloud Systems" class="h-10 w-auto" />
        </a>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          {t(lang, 'hero.subtitle').split('.')[0]}.
        </p>
        <p class="mt-3 text-xs text-brand-teal font-medium">
          {t(lang, 'general.since')}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-semibold text-slate-900 dark:text-white uppercase tracking-wider mb-4">
          {t(lang, 'footer.links')}
        </h4>
        <ul class="space-y-2.5">
          {navItems.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-slate-600 dark:text-slate-400 hover:text-brand-teal transition-colors duration-200">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-sm font-semibold text-slate-900 dark:text-white uppercase tracking-wider mb-4">
          {t(lang, 'services.title')}
        </h4>
        <ul class="space-y-2.5">
          <li class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'services.admin.title')}</li>
          <li class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'services.monitoring.title')}</li>
          <li class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'services.hosting.title')}</li>
          <li class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'services.security.title')}</li>
          <li class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'services.backup.title')}</li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-sm font-semibold text-slate-900 dark:text-white uppercase tracking-wider mb-4">
          {t(lang, 'footer.contact')}
        </h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'contact.info.address')}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+40761454443" class="text-sm text-slate-600 dark:text-slate-400 hover:text-brand-teal transition-colors">
              {t(lang, 'contact.info.phone')}
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:office@vmcloud.ro" class="text-sm text-slate-600 dark:text-slate-400 hover:text-brand-teal transition-colors">
              {t(lang, 'contact.info.email')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-slate-900/10 dark:border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        © 2014–{currentYear} {t(lang, 'footer.company')}. {t(lang, 'footer.rights')}
      </p>
      <div class="flex items-center gap-2 text-xs text-slate-600">
        <span>Built with</span>
        <svg class="w-3 h-3 text-brand-teal" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
        </svg>
        <span>by VMCloud</span>
      </div>
    </div>
  </div>
</footer>
