---
import ServiceCard from './ServiceCard.astro';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const services = [
  { icon: 'monitor',  titleKey: 'services.admin.title'        as const, descKey: 'services.admin.desc'        as const },
  { icon: 'activity', titleKey: 'services.monitoring.title'   as const, descKey: 'services.monitoring.desc'   as const },
  { icon: 'globe',    titleKey: 'services.hosting.title'      as const, descKey: 'services.hosting.desc'      as const },
  { icon: 'network',  titleKey: 'services.architecture.title' as const, descKey: 'services.architecture.desc' as const },
  { icon: 'shield',   titleKey: 'services.security.title'     as const, descKey: 'services.security.desc'     as const },
  { icon: 'database', titleKey: 'services.backup.title'       as const, descKey: 'services.backup.desc'       as const },
];
---

<section class="py-20 lg:py-28 relative overflow-hidden">
  <!-- Ambient background blobs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-brand-blue/5 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-[32rem] h-[32rem] rounded-full bg-brand-teal/5 blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">

    <!-- Section header -->
    <div class="text-center mb-14" data-animate>
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-teal/10 border border-brand-teal/25 text-brand-teal text-xs font-semibold tracking-widest uppercase mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-teal animate-pulse"></span>
        {t(lang, 'services.label')}
      </div>

      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">
        {t(lang, 'services.title')}
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {t(lang, 'services.subtitle')}
      </p>
    </div>

    <!-- Uniform 3-column grid — 2 columns on md, 3 columns on lg -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <ServiceCard
          title={t(lang, service.titleKey)}
          description={t(lang, service.descKey)}
          icon={service.icon}
        />
      ))}
    </div>

  </div>
</section>
