---
interface Props {
  quote: string;
  author: string;
  company: string;
  role: string;
  rating: number;
  featured?: boolean;
  verified?: boolean;
  delay?: string;
  readMoreLabel: string;
  readLessLabel: string;
  verifiedLabel: string;
}

const {
  quote,
  author,
  company,
  role,
  rating,
  featured = false,
  verified = false,
  delay = '',
  readMoreLabel,
  readLessLabel,
  verifiedLabel,
} = Astro.props;

const CHAR_LIMIT = 120;
const isLong = quote.length > CHAR_LIMIT;
const shortQuote = isLong ? quote.slice(0, CHAR_LIMIT).trimEnd() + '…' : quote;
const initials = author.split(' ').map(n => n.charAt(0)).join('').slice(0, 2);
---

<div
  class:list={[
    'testimonial-card relative rounded-2xl transition-all duration-500 group overflow-hidden',
    featured
      ? 'p-8 lg:p-10 bg-gradient-to-br from-surface-dark to-slate-900 border border-brand-teal/20 shadow-lg shadow-brand-teal/5 hover:shadow-brand-teal/15 hover:border-brand-teal/40'
      : 'p-6 lg:p-8 bg-white/5 border border-white/10 hover:border-white/20 hover:bg-white/[0.07]',
    delay
  ]}
  data-animate
>
  <!-- Background watermark quote -->
  <div class:list={[
    'absolute top-2 right-4 font-serif leading-none pointer-events-none select-none',
    featured ? 'text-[8rem] text-brand-teal/[0.07]' : 'text-[6rem] text-white/[0.04]'
  ]}>&ldquo;</div>

  <!-- Star Rating -->
  <div class="flex items-center gap-1 mb-4">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class:list={['w-4 h-4', i < rating ? 'text-brand-teal' : 'text-white/20']} fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <blockquote class="relative z-10 mb-6">
    {isLong ? (
      <div class="testimonial-toggle-wrapper">
        <p class="testimonial-short text-sm sm:text-base text-slate-300 leading-relaxed italic">
          {shortQuote}
          <button
            type="button"
            class="testimonial-read-more inline ml-1 text-brand-teal hover:text-brand-teal-light text-sm font-medium transition-colors cursor-pointer"
          >
            {readMoreLabel}
          </button>
        </p>
        <p class="testimonial-full text-sm sm:text-base text-slate-300 leading-relaxed italic hidden">
          {quote}
          <button
            type="button"
            class="testimonial-read-less inline ml-1 text-brand-teal hover:text-brand-teal-light text-sm font-medium transition-colors cursor-pointer"
          >
            {readLessLabel}
          </button>
        </p>
      </div>
    ) : (
      <p class="text-sm sm:text-base text-slate-300 leading-relaxed italic">{quote}</p>
    )}
  </blockquote>

  <!-- Divider -->
  <div class:list={[
    'h-px mb-5',
    featured ? 'bg-gradient-to-r from-transparent via-brand-teal/30 to-transparent' : 'bg-white/10'
  ]}></div>

  <!-- Author row -->
  <div class="flex items-center gap-4">
    <!-- Professional avatar -->
    <div class:list={[
      'relative shrink-0 w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm',
      featured
        ? 'bg-gradient-to-br from-brand-teal to-brand-blue text-white ring-2 ring-brand-teal/30'
        : 'bg-gradient-to-br from-brand-blue/60 to-brand-teal/60 text-white/90 ring-1 ring-white/10'
    ]}>
      <!-- Profile silhouette SVG -->
      <svg class="w-7 h-7 opacity-90" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v1.2c0 .7.5 1.2 1.2 1.2h16.8c.7 0 1.2-.5 1.2-1.2v-1.2c0-3.2-6.4-4.8-9.6-4.8z"/>
      </svg>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-sm font-semibold text-white">{author}</span>
        {verified && (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-brand-teal/15 text-brand-teal text-[10px] font-medium uppercase tracking-wider">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {verifiedLabel}
          </span>
        )}
      </div>
      <div class="text-xs text-slate-400 mt-0.5">{role}</div>
      <!-- Company logo placeholder -->
      <div class="flex items-center gap-1.5 mt-1">
        <div class:list={[
          'w-4 h-4 rounded flex items-center justify-center text-[8px] font-bold',
          featured ? 'bg-brand-teal/20 text-brand-teal' : 'bg-white/10 text-white/50'
        ]}>
          {company.charAt(0)}
        </div>
        <span class="text-xs text-brand-teal truncate">{company}</span>
      </div>
    </div>
  </div>
</div>

<script>
  function initTestimonialToggles() {
    document.querySelectorAll('.testimonial-toggle-wrapper').forEach(wrapper => {
      const shortEl = wrapper.querySelector('.testimonial-short') as HTMLElement;
      const fullEl = wrapper.querySelector('.testimonial-full') as HTMLElement;
      const readMoreBtn = wrapper.querySelector('.testimonial-read-more');
      const readLessBtn = wrapper.querySelector('.testimonial-read-less');

      readMoreBtn?.addEventListener('click', () => {
        shortEl.classList.add('hidden');
        fullEl.classList.remove('hidden');
      });

      readLessBtn?.addEventListener('click', () => {
        fullEl.classList.add('hidden');
        shortEl.classList.remove('hidden');
      });
    });
  }

  // Support both standard load and Astro View Transitions
  initTestimonialToggles();
  document.addEventListener('astro:page-load', initTestimonialToggles);
</script>
