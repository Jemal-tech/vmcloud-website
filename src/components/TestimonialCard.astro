---
interface Props {
  quote: string;
  author: string;
  company: string;
  delay?: string;
}

const { quote, author, company, delay = '' } = Astro.props;
---

<div class:list={['relative p-6 lg:p-8 rounded-2xl glass-light group hover:bg-slate-900/10 dark:hover:bg-white/10 transition-all duration-500', delay]} data-animate>
  <!-- Quote mark -->
  <div class="absolute -top-3 left-6 text-4xl text-brand-teal/30 font-serif">"</div>

  <blockquote class="text-sm sm:text-base text-slate-700 dark:text-slate-300 leading-relaxed mb-6 italic">
    {quote}
  </blockquote>

  <div class="flex items-center gap-3">
    <!-- Avatar placeholder -->
    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-blue to-brand-teal flex items-center justify-center text-slate-900 dark:text-white font-bold text-sm">
      {author.charAt(0)}
    </div>
    <div>
      <div class="text-sm font-semibold text-slate-900 dark:text-white">{author}</div>
      <div class="text-xs text-brand-teal">{company}</div>
    </div>
  </div>
</div>
