---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'ro';

const codeSnippets = [
  `const net = {\n  nodes: 15,\n  uptime: 99.9,\n  secure: true\n};`,
  `ssh root@srv01\n> status: online\n> health: ok\n> backup: ✓`,
  `deploy(config);\nmonitor(nodes);\nlog("ready");`,
];

const projects = [
  {
    title: 'Cremeria Emilia Romania',
    category: 'Administrare IT Completă',
    description: 'Administrare completă a infrastructurii IT pentru lanțul de cofetării, inclusiv rețelistică, servere și suport pentru 15+ locații.',
    tags: ['Rețelistică', 'Servere', 'Suport 24/7'],
  },
  {
    title: 'Spitalul Clinic „Sfânta Maria"',
    category: 'Infrastructură Critică',
    description: 'Modernizarea și administrarea infrastructurii IT pentru una din cele mai importante instituții medicale din București.',
    tags: ['Securitate', 'Infrastructură', 'Backup'],
  },
  {
    title: 'Școala Germană „Hermann Oberth"',
    category: 'Soluții Educaționale',
    description: 'Implementarea și administrarea soluțiilor IT pentru mediul educațional, inclusiv rețele de clase și sisteme de e-learning.',
    tags: ['E-learning', 'Rețelistică', 'Webhosting'],
  },
];
---

<BaseLayout title={t(lang, 'nav.portfolio')}>
  <section class="relative py-20 lg:py-28">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-blue/5 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6 animate-fade-in-up">
          {t(lang, 'portfolio.title')}
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed animate-fade-in-up delay-100">
          {t(lang, 'portfolio.subtitle')}
        </p>
        <div class="mt-6 w-20 h-1 bg-gradient-to-r from-brand-blue to-brand-teal rounded-full animate-fade-in-up delay-200"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project, i) => (
          <article class:list={['group relative p-6 lg:p-8 rounded-2xl bg-slate-100/80 dark:bg-slate-950/60 backdrop-blur-xl border border-slate-200 dark:border-white/10 hover:border-brand-teal/40 dark:hover:border-brand-teal/50 shadow-lg hover:shadow-brand-teal/10 dark:hover:shadow-brand-teal/20 transition-all duration-500 hover:-translate-y-1 overflow-hidden', i === 1 ? 'delay-100' : i === 2 ? 'delay-200' : '']} data-animate>

            {/* Tech-Mesh SVG background pattern */}
            <div class="absolute inset-0 opacity-[0.07] dark:opacity-[0.12] pointer-events-none" aria-hidden="true">
              <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <pattern id={`mesh-ro-${i}`} x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
                    <circle cx="10" cy="10" r="1.5" fill="currentColor" class="text-brand-teal" />
                    <circle cx="50" cy="15" r="1" fill="currentColor" class="text-brand-blue" />
                    <circle cx="30" cy="45" r="1.5" fill="currentColor" class="text-brand-teal" />
                    <circle cx="5" cy="50" r="1" fill="currentColor" class="text-brand-blue" />
                    <circle cx="55" cy="48" r="1" fill="currentColor" class="text-brand-teal" />
                    <line x1="10" y1="10" x2="50" y2="15" stroke="currentColor" stroke-width="0.5" class="text-brand-teal" />
                    <line x1="50" y1="15" x2="30" y2="45" stroke="currentColor" stroke-width="0.5" class="text-brand-blue" />
                    <line x1="30" y1="45" x2="10" y2="10" stroke="currentColor" stroke-width="0.5" class="text-brand-teal" />
                    <line x1="30" y1="45" x2="5" y2="50" stroke="currentColor" stroke-width="0.5" class="text-brand-blue" />
                    <line x1="50" y1="15" x2="55" y2="48" stroke="currentColor" stroke-width="0.5" class="text-brand-teal" />
                    <line x1="5" y1="50" x2="55" y2="48" stroke="currentColor" stroke-width="0.5" class="text-brand-blue" />
                  </pattern>
                </defs>
                <rect width="100%" height="100%" fill={`url(#mesh-ro-${i})`} />
              </svg>
            </div>

            {/* Blurred code-snippet aesthetic overlay */}
            <div class="absolute top-2 right-2 opacity-[0.04] dark:opacity-[0.06] pointer-events-none select-none blur-[1px] text-[10px] leading-tight font-mono text-brand-teal whitespace-pre" aria-hidden="true">{codeSnippets[i]}</div>

            <div class="relative z-10">
              <div class="inline-flex items-center px-3 py-1 rounded-full bg-brand-teal/10 border border-brand-teal/20 text-brand-teal text-xs font-medium mb-4">
                {project.category}
              </div>
              <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-brand-teal transition-colors duration-300">
                {project.title}
              </h2>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="px-3 py-1 rounded-full text-xs font-medium bg-brand-teal/10 dark:bg-brand-teal/5 text-brand-teal border border-brand-teal/30 shadow-[0_0_8px_rgba(45,212,191,0.15)] dark:shadow-[0_0_10px_rgba(45,212,191,0.2)] transition-shadow duration-300 group-hover:shadow-[0_0_12px_rgba(45,212,191,0.25)] dark:group-hover:shadow-[0_0_14px_rgba(45,212,191,0.3)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-brand-blue to-brand-teal opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </article>
        ))}
      </div>

      <!-- <div class="mt-12 text-center" data-animate>
        <p class="text-sm text-slate-500 italic">Mai multe proiecte în curând...</p>
      </div> -->
    </div>
  </section>
</BaseLayout>
