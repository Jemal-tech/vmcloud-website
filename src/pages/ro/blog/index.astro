---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'ro';

// Sample blog posts (will be replaced with content collections later)
const posts = [
  {
    title: 'De ce outsourcing-ul IT este viitorul pentru IMM-uri',
    excerpt: 'Descoperă avantajele externalizării departamentului IT și cum poate economisi costuri semnificative pentru compania ta.',
    date: '2026-03-15',
    slug: 'outsourcing-it-imm',
    readTime: '5 min',
  },
  {
    title: 'Ghid complet: Securitatea cibernetică pentru afaceri mici',
    excerpt: 'Protejează-ți afacerea de amenințări cibernetice cu aceste practici esențiale de securitate IT.',
    date: '2026-03-10',
    slug: 'securitate-cibernetica-ghid',
    readTime: '8 min',
  },
  {
    title: 'Backup în cloud: Ce trebuie să știi în 2026',
    excerpt: 'Strategii de backup și recuperare a datelor care pot salva afacerea ta de pierderi catastrofale.',
    date: '2026-03-05',
    slug: 'backup-cloud-2026',
    readTime: '6 min',
  },
];
---

<BaseLayout title={t(lang, 'nav.blog')}>
  <section class="relative py-20 lg:py-28">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-blue/5 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6 animate-fade-in-up">
          {t(lang, 'blog.title')}
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed animate-fade-in-up delay-100">
          {t(lang, 'blog.subtitle')}
        </p>
        <div class="mt-6 w-20 h-1 bg-gradient-to-r from-brand-blue to-brand-teal rounded-full animate-fade-in-up delay-200"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <article class:list={['group p-6 lg:p-8 rounded-2xl glass-light hover:bg-slate-900/10 dark:bg-white/10 transition-all duration-500 hover:-translate-y-1', i === 1 ? 'delay-100' : i === 2 ? 'delay-200' : '']} data-animate>
            <!-- Date badge -->
            <div class="flex items-center gap-3 mb-4">
              <time class="text-xs text-brand-teal font-medium">{new Date(post.date).toLocaleDateString('ro-RO', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span class="text-xs text-slate-500">•</span>
              <span class="text-xs text-slate-500">{post.readTime}</span>
            </div>

            <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-3 group-hover:text-brand-teal transition-colors duration-300 line-clamp-2">
              {post.title}
            </h2>

            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-6 line-clamp-3">
              {post.excerpt}
            </p>

            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-teal group-hover:gap-3 transition-all duration-300">
              {t(lang, 'blog.read-more')}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </article>
        ))}
      </div>

      <!-- Coming soon note -->
      <!-- <div class="mt-12 text-center" data-animate>
        <p class="text-sm text-slate-500 italic">Mai multe articole în curând...</p>
      </div> -->
    </div>
  </section>
</BaseLayout>
